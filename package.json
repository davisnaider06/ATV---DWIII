{
  "name": "sistema-reservas-mesa",
  "version": "1.0.0",
  "description": "Sistema de Reservas de Mesa - Backend TypeScript + Express + MongoDB (Prova 2 - Desenvolvimento Web III)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
